{
  "schemaId": "agent.semantic-protocols.hook.provider-manifest",
  "schemaVersion": "1",
  "protocolId": "agent.semantic-protocols.hook",
  "protocolVersion": "1",
  "manifestId": "agent.semantic-protocols.providers.rust.rs-harness",
  "manifestVersion": "v1",
  "languageId": "rust",
  "providerId": "rs-harness",
  "namespace": "agent.semantic-protocols.languages.rust.rs-harness",
  "binary": "rs-harness",
  "execution": "external-process",
  "source": {
    "defaultExtensions": [
      ".rs"
    ],
    "defaultConfigFiles": [
      "Cargo.toml"
    ],
    "defaultSourceRoots": [
      "src",
      "crates",
      "tests"
    ],
    "defaultIgnoredPathPrefixes": [
      "target"
    ],
    "defaultProjectMarkers": [
      "Cargo.toml"
    ],
    "defaultDependencyMarkers": [
      "Cargo.toml",
      "Cargo.lock"
    ]
  },
  "searchCapabilities": {
    "sourceSnapshot": {
      "descriptorId": "rust.source-snapshot",
      "descriptorVersion": "1",
      "languageId": "rust",
      "packetSchemaId": "asp.source-snapshot.v1",
      "exactSourcePacketSchemaId": "asp.exact-source-query-result.v1",
      "sourceOverlaySchemaId": "asp.exact-source-snapshot-envelope.v1",
      "derivedArtifactEvidenceSchemaId": "asp.derived-source-artifact-evidence.v1",
      "algorithm": "blake3-merkle-v1",
      "authority": "live-parser",
      "exactSelectorResolution": "pinned-live-module-graph",
      "overlayMode": "merkle-delta"
    },
    "ownerItems": false,
    "semanticFacts": true,
    "dependencyTopology": true,
    "dependencyTopologyMetadata": true,
    "workspaceScope": true
  },
  "semanticFactsDescriptor": {
    "descriptorId": "rust.semantic-facts",
    "descriptorVersion": "1",
    "packetSchemaIds": [
      "agent.semantic-protocols.semantic-fact-graph"
