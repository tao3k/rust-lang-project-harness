{
  "schemaId": "agent.semantic-protocols.hook.provider-manifest",
  "schemaVersion": "1",
  "protocolId": "agent.semantic-protocols.hook",
  "protocolVersion": "1",
  "manifestId": "agent.semantic-protocols.providers.rust.rs-harness",
  "manifestVersion": "v1",
  "languageId": "rust",
  "providerId": "rs-harness",
  "namespace": "agent.semantic-protocols.languages.rust.rs-harness",
  "binary": "rs-harness",
  "execution": "external-process",
  "source": {
    "defaultExtensions": [
      ".rs"
    ],
    "defaultConfigFiles": [
      "Cargo.toml"
    ],
    "defaultSourceRoots": [
      "src",
      "crates",
      "tests"
    ],
    "defaultIgnoredPathPrefixes": [
      "target"
    ],
    "defaultProjectMarkers": [
      "Cargo.toml"
    ],
    "defaultDependencyMarkers": [
      "Cargo.toml",
      "Cargo.lock"
    ]
  },
  "searchCapabilities": {
    "semanticFacts": true,
    "dependencyTopology": true,
    "dependencyTopologyMetadata": true
  },
  "policy": {
    "directSourceRead": "block",
    "bulkSourceDump": "block",
    "rawSourceSearch": "block",
    "agentSearchJson": "block"
  },
  "routes": {
    "prime": {
      "argv": [
        "rs-harness",
        "search",
        "prime",
        "--workspace",
        "{projectRoot}",
        "--view",
        "seeds"
      ]
    },
    "owner": {
      "argv": [
        "rs-harness",
        "search",
        "owner",
        "{path}",
        "--workspace",
        "{projectRoot}",
        "--view",
        "seeds"
      ]
    },
    "fzf": {
      "argv": [
        "rs-harness",
        "search",
        "fzf",
        "{query}",
        "owner",
        "tests",
        "--workspace",
        "{projectRoot}",
        "--view",
        "seeds"
      ]
    },
    "query": {
      "argv": [
        "rs-harness",
        "query",
        "--from-hook",
        "direct-source-read",
        "--selector",
        "{selector}",
        "{termArgs}",
        "--surface",
        "owners,tests",
        "--workspace",
        "{projectRoot}",
        "--view",
        "seeds"
      ]
    },
    "ingest": {
      "argv": [
        "rs-harness",
        "search",
        "ingest",
        "items",
        "tests",
        "--workspace",
        "{projectRoot}",
        "--view",
        "seeds"
      ],
      "stdinMode": "pipe-candidates"
    },
    "dependencyTopology": {
      "argv": [
        "rs-harness",
        "search",
        "dependency-topology",
        "--json",
        "--workspace",
        "{projectRoot}"
      ]
    },
    "dependencyTopologyMetadata": {
      "argv": [
        "rs-harness",
        "search",
        "dependency-topology-metadata",
        "--json",
        "--workspace",
        "{projectRoot}"
      ]
    },
    "checkChanged": {
      "argv": [
        "rs-harness",
        "check",
        "--changed",
        "{projectRoot}"
      ]
    },
    "guide": {
      "argv": [
        "rs-harness",
        "guide",
        "{projectRoot}"
      ]
    }
  }
}
