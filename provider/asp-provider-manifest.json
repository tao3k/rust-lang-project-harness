      {
        "recipeId": "rust-concurrency-runtime",
        "trigger": {
          "terms": [
            "concurrency",
            "runtime",
            "scheduling"
          ],
          "match": "any"
        },
        "clauses": [
          {
            "terms": [
              "concurrency",
              "runtime",
              "scheduling"
            ],
            "roles": [
              "concept"
            ],
            "intentAxes": [
              "concurrency"
            ]
          }
        ]
      },
      {
        "recipeId": "rust-resource-lifecycle",
        "trigger": {
          "terms": [
            "scope",
            "lifecycle",
            "drop"
          ],
          "match": "any"
        },
        "clauses": [
          {
            "terms": [
              "scope",
              "lifecycle",
              "drop"
            ],
            "roles": [
              "concept"
            ],
            "intentAxes": [
              "resource-lifecycle"
            ]
          }
        ]
      },
      {
        "recipeId": "rust-stream-backpressure",
        "trigger": {
          "terms": [
            "queue",
            "stream",
            "backpressure"
          ],
          "match": "any"
        },
        "clauses": [
          {
            "terms": [
              "queue",
              "stream",
              "backpressure"
            ],
            "roles": [
              "concept"
            ],
            "intentAxes": [
              "collection",
              "stream"
            ]
