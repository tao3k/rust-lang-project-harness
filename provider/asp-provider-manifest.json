    "factKinds": [
      "owner",
      "field",
      "type",
      "collection"
    ],
    "intentAxes": [
      {
        "axis": "data-shape",
        "terms": [
          "field",
          "fields",
          "scalar"
        ]
      },
      {
        "axis": "collection",
        "terms": [
          "collection",
          "Vec"
        ]
      }
    ]
  },
  "policy": {
    "directSourceRead": "block",
    "bulkSourceDump": "block",
    "rawSourceSearch": "block",
    "agentSearchJson": "block"
  },
  "queryPackDescriptor": {
    "descriptorId": "rust.query-pack",
