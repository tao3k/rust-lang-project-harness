{
  "$id": "https://agent-semantic-protocols.local/schemas/semantic-compare-packet.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Semantic Compare Packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "schemaVersion",
    "protocolId",
    "protocolVersion",
    "languageId",
    "providerId",
    "namespace",
    "authority",
    "evidenceGrade",
    "quality",
    "query",
    "comparisons",
    "missing",
    "witness",
    "next"
  ],
  "properties": {
    "schemaId": {
      "const": "agent.semantic-protocols.semantic-compare-packet"
    },
    "schemaVersion": {
      "const": "1"
    },
    "protocolId": {
      "const": "agent.semantic-protocols.semantic-language"
    },
    "protocolVersion": {
      "const": "1"
    },
    "languageId": {
      "type": "string",
      "minLength": 1
    },
    "providerId": {
      "type": "string",
      "minLength": 1
    },
    "namespace": {
      "const": "compare"
    },
    "authority": {
      "type": "string",
      "minLength": 1
    },
    "evidenceGrade": {
      "enum": ["fact", "unknown"]
    },
    "quality": {
      "enum": ["verified", "insufficient"]
    },
    "query": {
      "type": "string"
    },
    "comparisons": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/comparison"
      }
    },
    "missing": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "witness": {
      "type": "string",
      "minLength": 1
    },
    "next": {
      "type": "string",
      "pattern": "^search "
    }
  },
  "$defs": {
    "comparison": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "summary",
        "evidenceGrade",
        "witness",
        "next",
        "left",
        "right",
        "result",
        "agentScenario",
        "intent",
        "qualitySignals",
        "failureCases"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "evidenceGrade": {
          "enum": ["fact", "unknown"]
        },
        "witness": {
          "type": "string",
          "minLength": 1
        },
        "next": {
          "type": "string",
          "pattern": "^search "
        },
        "left": {
          "$ref": "#/$defs/side"
        },
        "right": {
          "$ref": "#/$defs/side"
        },
        "result": {
          "type": "string",
          "minLength": 1
        },
        "agentScenario": {
          "type": "string",
          "minLength": 1
        },
        "intent": {
          "type": "string",
          "minLength": 1
        },
        "qualitySignals": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "failureCases": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/failureCase"
          }
        }
      }
    },
    "side": {
      "type": "object",
      "additionalProperties": true,
      "required": ["kind"],
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "failureCase": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "risk": {
          "type": "string"
        },
        "correction": {
          "type": "string"
        }
      }
    }
  }
}
