        "RustNativeSyntaxFacts.macro_invocations",
        "RustInvocationSyntax.terminal_name",
        "RustInvocationSyntax.argument_top_level_idents",
        "RustInvocationSyntax.argument_token_count"
      ],
      "catalogId": "macros",
      "captures": [
        "macro.invocation",
        "macro.name",
        "macro.arguments"
      ],
      "projectionMode": "native-to-tree-sitter-captures"
    },
    {
      "semanticFact": "attribute.cfg",
      "nativeFacts": [
        "RustTopLevelItemSyntax.has_cfg_attr",
        "RustNativeSyntaxFacts.cfg_test_modules"
      ],
      "catalogId": "cfg",
      "captures": [
        "attribute.item",
        "attribute.name",
        "attribute.body",
        "attribute.arguments",
        "attribute.value"
      ],
      "projectionMode": "native-to-tree-sitter-captures"
    }
