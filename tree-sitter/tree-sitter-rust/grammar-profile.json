        "RustTopLevelItemSyntax.kind",
        "RustTopLevelItemSyntax.name",
        "RustTopLevelItemSyntax.impl_target_name",
        "RustTopLevelItemSyntax.module"
      ],
      "catalogId": "declarations",
      "captures": [
        "function.definition",
        "function.name",
        "type.definition",
        "type.name",
        "trait.definition",
        "trait.name",
        "impl.definition",
        "impl.target",
        "impl.trait",
        "module.definition",
        "module.name",
        "constant.definition",
        "constant.name"
      ],
      "projectionMode": "native-to-tree-sitter-captures"
    },
    {
      "semanticFact": "item.modifier",
      "nativeFacts": [
        "RustTopLevelItemSyntax.is_public",
        "RustTopLevelItemSyntax.has_doc",
        "RustTopLevelItemSyntax.has_cfg_attr",
        "RustTopLevelItemSyntax.has_proc_macro_export_attr"
      ],
      "catalogId": "declarations",
      "captures": [
        "item.visibility",
        "item.attribute",
        "function.modifier",
        "function.type_parameters",
        "function.return_type",
        "type.type_parameters",
        "type.aliased_type",
        "trait.type_parameters",
        "trait.bounds",
        "impl.type_parameters",
        "constant.type"
      ],
      "projectionMode": "native-to-tree-sitter-captures"
    },
    {
      "semanticFact": "import.binding",
      "nativeFacts": [
        "RustNativeSyntaxFacts.use_statements",
        "RustTopLevelItemSyntax.is_public_use",
        "RustTopLevelItemSyntax.is_extern_crate"
      ],
      "catalogId": "imports",
      "captures": [
        "import.declaration",
        "import.path",
        "import.alias",
        "import.visibility"
      ],
      "projectionMode": "native-to-tree-sitter-captures"
    },
    {
      "semanticFact": "invocation.call",
      "nativeFacts": [
        "RustNativeSyntaxFacts.function_calls",
        "RustInvocationSyntax.terminal_name",
        "RustInvocationSyntax.argument_top_level_idents",
        "RustInvocationSyntax.argument_token_count"
      ],
      "catalogId": "calls",
      "captures": [
        "call.expression",
        "call.target",
        "call.method"
      ],
      "projectionMode": "native-to-tree-sitter-captures"
