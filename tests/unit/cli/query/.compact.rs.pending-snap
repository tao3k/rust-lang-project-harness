{"run_id":"1780631980-368232000","line":27,"new":{"module_name":"unit_test__cli__query__compact","snapshot_name":"cli_query_parser_code_source_slice_snapshot","metadata":{"source":"tests/unit/cli/query/compact.rs","assertion_line":27,"expression":"stdout.trim_end()"},"snapshot":"pub fn branch_and_write(flag: bool, block: &mut String) -> Option<String> {\n    if let Some(line) = flag.then_some(\"ok\") {\n        let _ = writeln!(block, \"{line}\");\n        return Some(line.to_string());\n    }\n\n    None\n}\npub fn match_and_loop(values: &[String]) -> usize {\n    let mut count = 0;\n    for value in values {\n        match value.as_str() {\n            \"skip\" => continue,\n            _ => count += 1,\n        }\n    }\n    count\n}"},"old":{"module_name":"unit_test__cli__query__compact","metadata":{},"snapshot":"fn branch_and_write(flag: bool, block: &mut String) -> Option<String> {\n    if let Some(line) = flag.then_some(\"ok\") {\n        writeln!(block, \"{line}\");\n        return Some(line.to_string());\n    }\n    None\n}\nfn match_and_loop(values: &[String]) -> usize {\n    let mut count = 0;\n    for value in values {\n        match value.as_str() {\n            \"skip\" => {\n                continue;\n            }\n            _ => {\n                count += 1;\n            }\n        }\n    }\n    count\n}"}}
