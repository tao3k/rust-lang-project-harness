{
  "mode": "apply",
  "expectedStatus": "applied",
  "expectedCapability": "provider-ast-apply",
  "expectedMutationAvailable": true,
  "expectedOperation": "replace_item",
  "expectedFailureKind": null,
  "verificationContains": [
    "packet-parsed",
    "operation-supported",
    "snippet-parsed",
    "expected-snippet-matched",
    "target-item-parsed",
    "item-identity-checked",
    "file-reparsed",
    "file-written",
    "rustfmt-ran",
    "formatter-output-reparsed"
  ],
  "compactChecks": [
    {
      "path": "src/runtime/builder.rs",
      "query": "Builder",
      "matchKind": "struct",
      "matchName": "Builder",
      "codeFixture": "compact/expected.code.txt",
      "assertRustfmtStyleCompact": true,
      "saveApplyPatch": "compact/apply-patch.json",
      "codeNotContains": [
        "#[cfg"
      ],
      "exactContains": [
        "#[cfg(feature = \"rt\")]",
        "pub(crate) thread_name: Option<String>"
      ],
      "assertCompactShorter": true,
      "minimumFunctionalComplexity": {
        "minDistinctResponsibilities": 2,
        "requiredResponsibilities": [
          "cfg-feature-gate",
          "data-shape"
        ],
        "requiredNativeParserResponsibilities": [
          "cfg-feature-gate"
        ],
        "requiredProjectionNodeResponsibilities": [
          "data-shape"
        ],
        "maxCompactToExactRatio": 1
      }
    }
  ]
}
